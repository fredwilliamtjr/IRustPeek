{
  "name": "irustpeek",
  "version": "0.1.5",
  "description": "Catálogo sincronizável de endereços RustDesk para macOS e Windows.",
  "main": "src/main.js",
  "author": "Fred William",
  "license": "TBD",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "build:mac:dir": "electron-builder --mac dir",
    "build:mac:universal": "electron-builder --mac dir --universal",
    "build:win": "electron-builder --win",
    "build:win:dir": "electron-builder --win dir",
    "build:win:portable": "electron-builder --win portable"
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "br.com.fredwilliam.irustpeek",
    "productName": "IRustPeek",
    "directories": {
      "output": "release"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "build/icon.icns",
      "extendInfo": {
        "LSUIElement": true
      },
      "target": [
        "dmg"
      ]
    },
    "win": {
      "icon": "build/icon.png",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
